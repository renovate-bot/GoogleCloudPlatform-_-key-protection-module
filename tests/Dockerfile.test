FROM golang:1.24-bookworm

# Install Rust
ARG RUSTUP_VERSION="1.26.0"
ARG RUSTUP_INIT_SHA256="0b2f6c8f85a3d02fde2efc0ced4657869d73fccfce59defb4e8d29233116e6db"
RUN curl -sSfL "https://static.rust-lang.org/rustup/archive/${RUSTUP_VERSION}/x86_64-unknown-linux-gnu/rustup-init" -o rustup-init \
    && echo "${RUSTUP_INIT_SHA256} *rustup-init" | sha256sum -c - \
    && chmod +x rustup-init \
    && ./rustup-init -y --no-modify-path --profile minimal \
    && rm rustup-init
ENV PATH="/root/.cargo/bin:${PATH}"

# Install build dependencies
RUN apt-get update && apt-get install -y \
    curl \
    tar \
    g++ \
    libssl-dev \
    pkg-config \
    clang \
    libclang-dev \
    git \
    protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

# Install CMake 3.28.3
RUN curl -sSL https://github.com/Kitware/CMake/releases/download/v3.28.3/cmake-3.28.3-linux-x86_64.tar.gz -o cmake.tar.gz \
    && tar -zxvf cmake.tar.gz -C /opt/ \
    && rm cmake.tar.gz
ENV PATH="/opt/cmake-3.28.3-linux-x86_64/bin:${PATH}"

# Install cbindgen and bindgen-cli and protoc-gen-go
RUN cargo install --locked --version 0.29.2 cbindgen && \
    cargo install --locked --version 0.72.1 bindgen-cli
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@v1.36.11
ENV PATH="/root/go/bin:${PATH}"

WORKDIR /app
COPY . .

# Generate FFI headers and build Rust in debug mode for faster tests
RUN ./generate_ffi_headers.sh

# Build without cache mount for target to ensure artifacts persist for the ENTRYPOINT
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    cargo build --locked --workspace

# The entrypoint runs all tests and exits with the corresponding code
ENTRYPOINT ["/bin/bash", "-c", "set -o pipefail && cargo test --locked --workspace && GOCACHE=/tmp/go-cache go test -v ./... && GOCACHE=/tmp/go-cache go test -v -race -tags integration ./..."]
